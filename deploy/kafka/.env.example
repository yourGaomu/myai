KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9092

# Keep this value stable after Kafka data has been created.
KAFKA_CLUSTER_ID=q1Sh-9_ISia_zwGINzRvyQ

KAFKA_DEFAULT_PARTITIONS=3
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Comma separated topic list created by kafka-init.
KAFKA_INIT_TOPICS=myai.events,myai.assets,myai.tasks,myai.audit

# Optional Kafka UI port. Start it with: docker compose --profile ui up -d
KAFKA_UI_PORT=8088
